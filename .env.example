# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/interlinedlist?schema=public"

# ── Application ───────────────────────────────────────────────────────────────
# Canonical base URL of this deployment, no trailing slash.
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Display/metadata. APP_USER_AGENT should include a contact email.
APP_NAME="InterlinedList"
APP_USER_AGENT="InterlinedList/1.0 (+https://interlinedlist.com; contact@interlinedlist.com)"
APP_CONTACT_EMAIL="contact@interlinedlist.com"

# Session cookie configuration.
SESSION_COOKIE_NAME="interlinedlist_session"
SESSION_MAX_AGE="2592000"   # 30 days, in seconds

# First-party analytics. Set to "false" to disable ingestion.
ANALYTICS_ENABLED="true"

# ── Cron ──────────────────────────────────────────────────────────────────────
# Shared secret enforced by /api/cron/* routes. Set to a strong random string in
# production. Without it the routes fail closed.
CRON_SECRET="dev-cron-secret-change-in-production"

# Emergency: skip Prisma migrate deploy during the Vercel build. Leave unset
# unless you're intentionally skipping migrations for a particular deploy.
# SKIP_DB_MIGRATE="true"

# ── OAuth: LinkedIn ───────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID="client_id_goes_here"
LINKEDIN_CLIENT_SECRET="client_secret_goes_here"
# Optional overrides. Must exactly match what is registered in the LinkedIn
# Developer Portal > Auth > Authorized redirect URLs.
# LINKEDIN_REDIRECT_URI="http://localhost:3000/api/auth/linkedin/callback"
# LINKEDIN_ORG_REDIRECT_URI="http://localhost:3000/api/auth/linkedin/org-callback"

# ── OAuth: Bluesky (AT Protocol) ──────────────────────────────────────────────
# The URL of the client-metadata document served by /api/oauth/client-metadata.
# This URL is also the Bluesky client id.
BLUESKY_CLIENT_ID="https://127.0.0.1:3000/api/oauth/client-metadata"

# ── OAuth: GitHub ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID="client_id_goes_here"
GITHUB_CLIENT_SECRET="client_secret_goes_here"

# ── OAuth: Twitter / X ────────────────────────────────────────────────────────
TWITTER_CLIENT_ID="client_id_goes_here"
TWITTER_CLIENT_SECRET="client_secret_goes_here"
# Optional override. Must match a registered Callback URI in the Twitter
# Developer Portal.
# TWITTER_REDIRECT_URI="http://localhost:3000/api/auth/twitter/callback"

# ── Mobile OAuth ──────────────────────────────────────────────────────────────
# Comma-separated allowlist of redirect URIs accepted by Mastodon, Bluesky,
# LinkedIn, GitHub, and Twitter OAuth callbacks. Must include both the web
# callback and the iOS custom URL scheme. The custom scheme must exactly match
# what is registered in Xcode (Info → URL Types → URL Schemes) and used in
# ASWebAuthenticationSession. See docs/mobile-client-setup.md.
OAUTH_ALLOWED_REDIRECT_URIS="http://localhost:3000/oauth/callback,interlinedlist://oauth/callback"

# ── Object Storage: Vercel Blob ───────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_thekeyhere"

# ── Transactional Email: Resend ───────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="support@interlinedlist.com"
RESEND_WEBHOOK_SECRET="whsec_..."

# ── Subscriptions: Stripe ─────────────────────────────────────────────────────
# Use test keys for local/sandbox.
STRIPE_SECRET_KEY="sk_test_..."
# For local: use Stripe CLI (stripe listen --forward-to localhost:3000/api/webhooks/stripe)
# to obtain the webhook secret.
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs from Stripe Dashboard (Products > Prices).
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_ANNUAL="price_..."
# Expose price IDs to client for checkout (same values).
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL="price_..."
# Display labels for subscription buttons - escape $ as \$ to prevent env expansion.
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY_LABEL="\$6.99/mo"
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL_LABEL="\$60/yr"

# ── Apple Push Notifications (APNs) ───────────────────────────────────────────
# Required for iOS push notifications. See docs/mobile-client-setup.md.
#
# APNS_KEY_ID    — 10-char Key ID shown after creating an APNs key in Apple
#                  Developer Console → Certificates, Identifiers & Profiles →
#                  Keys → Create Key (enable APNs)
# APNS_TEAM_ID   — 10-char Team ID shown in Apple Developer Console → Account →
#                  Membership
# APNS_BUNDLE_ID — your iOS app's bundle identifier (set in Xcode → Signing &
#                  Capabilities)
# APNS_PRIVATE_KEY — full contents of the .p8 file downloaded when creating the
#                    key. Paste the multi-line PEM block; Vercel preserves
#                    newlines automatically. For other hosts, replace literal
#                    newlines with \n.
# APNS_PRODUCTION — false = sandbox (dev builds, TestFlight); true = production
#                    (App Store)
APNS_KEY_ID="ABC123DEF4"
APNS_TEAM_ID="ABCD1234EF"
APNS_BUNDLE_ID="com.interlinedlist.app"
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
MIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQg...replace with real key...
-----END PRIVATE KEY-----"
APNS_PRODUCTION="false"

# ── E2E test accounts (local dev + CI only — never use real user credentials) ─
# Create these accounts with: npx tsx scripts/seed-test-users.ts
TEST_USER_EMAIL="testuser@example.com"
TEST_USER_PASSWORD="testpassword1"
TEST_SUBSCRIBER_EMAIL="testsubscriber@example.com"
TEST_SUBSCRIBER_PASSWORD="testpassword2"
