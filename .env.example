# Database - Local Docker Development
DATABASE_URL="postgresql://the url goes here"

# Next.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-key-change-in-production"

# JWT
JWT_SECRET="dev-jwt-secret-key-change-in-production"
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-key-change-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# OAuth Providers (optional for now)
GITHUB_CLIENT_ID="client_id_goes_here"
GITHUB_CLIENT_SECRET="client_secret_goes_here"
BLUESKY_CLIENT_ID="https://127.0.0.1:3000/api/oauth/client-metadata"
LINKEDIN_CLIENT_ID="client_id_goes_here"
LINKEDIN_CLIENT_SECRET="client_secret_goes_here"
# Optional: override redirect URI if it differs from APP_URL (e.g. ngrok). Must match exactly what is registered in LinkedIn Developer Portal > Auth > Authorized redirect URLs.
# LINKEDIN_REDIRECT_URI="http://localhost:3000/api/auth/linkedin/callback"
TWITTER_CLIENT_ID="client_id_goes_here"
TWITTER_CLIENT_SECRET="client_secret_goes_here"
# Optional: override redirect URI. Must match a registered Callback URI in the Twitter Developer Portal.
# TWITTER_REDIRECT_URI="http://localhost:3000/api/auth/twitter/callback"

# Application - do NOT include trailing slash in URLs (e.g. https://interlinedlist.com)
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="production"

BLOB_READ_WRITE_TOKEN="vercel_blob_rw_thekeyhere"

RESEND_API_KEY=the_resend_api_key_here
RESEND_FROM_EMAIL="support@interlinedlist.com"
RESEND_WEBHOOK_SECRET="whsec_..."


# Stripe (use test keys for local/sandbox)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# For local: use Stripe CLI (stripe listen --forward-to localhost:3000/api/webhooks/stripe) to get webhook secret
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs from Stripe Dashboard (Products > Prices)
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_ANNUAL="price_..."
# Expose price IDs to client for checkout (same values)
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL="price_..."
# Display labels for subscription buttons - escape $ as \$ to prevent env expansion
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY_LABEL="\$6.99/mo"
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL_LABEL="\$60/yr"

# E2E test accounts (local dev + CI only — never use real user credentials)
# Create these accounts with: npx tsx scripts/seed-test-users.ts
TEST_USER_EMAIL="testuser@example.com"
TEST_USER_PASSWORD="testpassword1"
TEST_SUBSCRIBER_EMAIL="testsubscriber@example.com"
TEST_SUBSCRIBER_PASSWORD="testpassword2"

# ── Apple Push Notifications (APNs) ────────────────────────────────────────────
# Required for iOS push notifications. See documentation/mobile-client-setup.md.
#
# APNS_KEY_ID   — 10-char Key ID shown after creating an APNs key in Apple Developer Console
#                 → Certificates, Identifiers & Profiles → Keys → Create Key (enable APNs)
# APNS_TEAM_ID  — 10-char Team ID shown in Apple Developer Console → Account → Membership
# APNS_BUNDLE_ID — your iOS app's bundle identifier (set in Xcode → Signing & Capabilities)
# APNS_PRIVATE_KEY — full contents of the .p8 file downloaded when creating the key.
#                    Paste the multi-line PEM block; Vercel preserves newlines automatically.
#                    For other hosts, replace literal newlines with \n.
# APNS_PRODUCTION — false = sandbox (dev builds, TestFlight); true = production (App Store)
APNS_KEY_ID="ABC123DEF4"
APNS_TEAM_ID="ABCD1234EF"
APNS_BUNDLE_ID="com.interlinedlist.app"
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
MIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQg...replace with real key...
-----END PRIVATE KEY-----"
APNS_PRODUCTION="false"

# ── Mobile OAuth ────────────────────────────────────────────────────────────────
# Comma-separated allowlist of redirect URIs accepted by Mastodon, Bluesky, and
# LinkedIn OAuth callbacks. Must include both the web callback and the iOS custom
# URL scheme. The custom scheme must exactly match what is registered in Xcode
# (Info → URL Types → URL Schemes) and used in ASWebAuthenticationSession.
# See documentation/mobile-client-setup.md for the full OAuth flow.
OAUTH_ALLOWED_REDIRECT_URIS="http://localhost:3000/oauth/callback,interlinedlist://oauth/callback"



# Twitter Test
TWITTER_CLIENT_ID="id"
TWITTER_CLIENT_SECRET="vf_somethinganother"

# Twitter Prod
PROD_ConsumerKey=
PROD_Secret_Key=
PROD_Bearer_Token=
