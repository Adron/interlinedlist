{
  "name": "interlinedlist",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "dotenv -e .env.local -- playwright test",
    "test:e2e:headed": "dotenv -e .env.local -- playwright test --headed",
    "test:e2e:ui": "dotenv -e .env.local -- playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && node scripts/migrate-deploy.js && next build",
    "db:migrate": "node scripts/safe-migrate.js",
    "db:migrate:deploy": "node scripts/migrate-deploy.js",
    "db:migrate:diagnose": "node scripts/migrate-diagnose.js",
    "db:migrate:force": "dotenv -e .env.local -- prisma migrate dev",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "backup": "node scripts/backup-database.js",
    "restore": "node scripts/restore-database.js",
    "test-data:seed": "dotenv -e .env.local -- node test-data/seed-test-accounts.js",
    "cli:test": "make -C cli test",
    "cli:test-local": "node scripts/cli-test-local.js",
    "cli:build": "node scripts/deploy-all-production.js --binaries-only",
    "deploy-all-production": "node scripts/deploy-all-production.js",
    "docs:devops": "node scripts/generate-docs.js --perspective devops",
    "docs:user": "node scripts/generate-docs.js --perspective user",
    "docs:api": "node scripts/generate-docs.js --perspective api",
    "docs:openapi": "node scripts/generate-openapi.js",
    "docs:all": "node scripts/generate-docs.js --perspective all && node scripts/generate-openapi.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@atproto/oauth-client-node": "^0.4.1",
    "@prisma/client": "^5.19.0",
    "@uiw/react-md-editor": "^4.0.11",
    "@vercel/blob": "^2.2.0",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.3",
    "compromise": "^14.11.0",
    "elkjs": "^0.11.0",
    "gray-matter": "^4.0.3",
    "gulp": "^5.0.1",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "resend": "^6.6.0",
    "sass": "^1.97.1",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1",
    "swagger-ui-react": "^5.32.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "jsdom": "^25.0.1",
    "prisma": "^5.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.5"
  }
}
